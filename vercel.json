{
  "version": 2,
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.aiden-jp.net" }],
      "destination": "https://aiden-jp.net/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/orders", "destination": "/api/orders/__root" },
    { "source": "/api/chat", "destination": "/api/chat/__root" },
    { "source": "/", "destination": "/aiden-brand-sushiro.html" },
    { "source": "/legal", "destination": "/legal/index.html" },
    { "source": "/legal/", "destination": "/legal/index.html" },
    { "source": "/legal/:path", "destination": "/legal/:path" },
    { "source": "/((?!api/|legal/).*)", "destination": "/404.html" }
  ]
}
