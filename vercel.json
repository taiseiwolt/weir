{
  "version": 2,
  "framework": null,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.xorder.co.jp" }],
      "destination": "https://xorder.co.jp/:path",
      "permanent": true
    },
    { "source": "/weir-email-verified.html", "destination": "/verify-email", "permanent": true },
    { "source": "/weir-email-pending.html", "destination": "/verify-email/pending", "permanent": true },
    { "source": "/weir-password-reset.html", "destination": "/reset-password", "permanent": true },
    { "source": "/weir-guest-order.html", "destination": "/", "permanent": true },
    { "source": "/weir-terms.html", "destination": "/legal/terms", "permanent": true },
    { "source": "/weir-privacy.html", "destination": "/legal/privacy", "permanent": true },
    { "source": "/weir-privacy-policy.html", "destination": "/legal/privacy", "permanent": true },
    { "source": "/weir-tokushoho.html", "destination": "/legal/tokushoho", "permanent": true },
    { "source": "/weir-brand-stores-v1.4.html", "destination": "/weir-brand-stores.html", "permanent": true },
    { "source": "/weir-store-v5.4.html", "destination": "/weir-store.html", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/admin/:path*", "destination": "/api/admin/__root?path=:path*" },
    { "source": "/api/orders", "destination": "/api/orders/__root" },
    { "source": "/api/orders/:id/:action", "destination": "/api/orders/__root?id=:id&action=:action" },
    { "source": "/api/orders/:id", "destination": "/api/orders/__root?id=:id" },
    { "source": "/api/chat", "destination": "/api/chat/__root" },
    { "source": "/", "destination": "/brand.html" },
    { "source": "/legal", "destination": "/legal/index.html" },
    { "source": "/legal/", "destination": "/legal/index.html" },
    { "source": "/legal/privacy", "destination": "/weir-privacy.html" },
    { "source": "/legal/terms", "destination": "/weir-terms.html" },
    { "source": "/legal/tokushoho", "destination": "/weir-tokushoho.html" },
    { "source": "/legal/:path", "destination": "/legal/:path" },
    { "source": "/verify-email", "destination": "/weir-email-verified.html" },
    { "source": "/verify-email/pending", "destination": "/weir-email-pending.html" },
    { "source": "/reset-password", "destination": "/weir-password-reset.html" },
    { "source": "/:brand_slug/news/:news_id", "destination": "/brand-news-detail.html?news_id=:news_id" },
    { "source": "/:brand_slug/mypage/membership", "destination": "/weir-mypage-membership.html" },
    { "source": "/:brand_slug/:venue_slug/order", "destination": "/weir-order-store.html" },
    { "source": "/:brand_slug/:venue_slug/checkout", "destination": "/weir-order-checkout.html" },
    { "source": "/:brand_slug/menu", "destination": "/weir-brand-menu.html" },
    { "source": "/:brand_slug/stores", "destination": "/weir-brand-stores.html" },
    { "source": "/:brand_slug/membership", "destination": "/weir-membership.html" },
    { "source": "/:brand_slug/news", "destination": "/weir-brand-news.html" },
    { "source": "/:brand_slug/order", "destination": "/weir-order.html" },
    { "source": "/:brand_slug/mypage", "destination": "/weir-mypage.html" },
    { "source": "/:brand_slug/tracking", "destination": "/weir-order-tracking.html" },
    { "source": "/:brand_slug/sitemap", "destination": "/weir-sitemap.html" },
    { "source": "/:brand_slug/:venue_slug", "destination": "/weir-store.html" },
    { "source": "/:slug((?!api|legal|weir-|aiden-|brand|404|index|test-|e2e-|playwright|seed-|qa-|docs|public|menu|stores|membership|news|sitemap|privacy|terms|tokushoho|order|mypage|tracking|verify-email|reset-password|guest-order).*)", "destination": "/brand.html" },
    { "source": "/((?!api/|legal/).*)", "destination": "/404.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://js.stripe.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://iikwusprydaogzeslgdz.supabase.co https://images.unsplash.com https://*.tile.openstreetmap.org https://unpkg.com https://www.google.com; connect-src 'self' https://iikwusprydaogzeslgdz.supabase.co wss://iikwusprydaogzeslgdz.supabase.co https://api.stripe.com https://nominatim.openstreetmap.org https://zipcloud.ibsnet.co.jp https://xorder.co.jp; frame-src https://js.stripe.com"
        },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
